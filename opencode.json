{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "jira": {
            "type": "remote",
            "url": "https://mcp.atlassian.com/v1/mcp/authv2",
            "enabled": true
        }
    }
}